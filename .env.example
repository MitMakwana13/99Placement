# Server Configurations
PORT=5000
BASE_PATH=/

# Database (PostgreSQL)
# E.g., postgresql://gg_user:gg_dev_password@localhost:5432/placement
DATABASE_URL=

# Authentication Secrets
# Generate secure random strings for production
SESSION_SECRET=
JWT_SECRET=
JWT_REFRESH_SECRET=

# Redis (Upstash) - Required for Queues & Webhooks
REDIS_URL=

# AI Integration
# E.g., OPENAI_API_KEY or Anthropic Key
AI_API_KEY=

# Cloudflare R2 / AWS S3 Storage
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=
S3_ENDPOINT=

# Emails & Notifications
RESEND_API_KEY=
SENDER_EMAIL=
