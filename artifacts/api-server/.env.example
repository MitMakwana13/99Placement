# ==============================================================================
# ENVIRONMENT CONFIGURATION EXAMPLE FOR TALENTLAB API SERVER
# ==============================================================================

# Server Context
PORT=5000
NODE_ENV=development
APP_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000
LOG_LEVEL=info

# Database (PostgreSQL via Prisma)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://gg_user:gg_dev_password@localhost:5432/placement

# JWT Configuration
JWT_SECRET=super_secret_jwt_access_sign_key_change_in_production
JWT_REFRESH_SECRET=super_secret_jwt_refresh_sign_key_change_in_production

# Redis Session & Cache Store
REDIS_URL=redis://localhost:6379

# Email Transmission Setup (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=test_smtp_user
SMTP_PASS=test_smtp_password
SMTP_FROM=no-reply@talentlab.io

# Cloudinary Assets Storage Setup
CLOUDINARY_CLOUD_NAME=cloudinary_test_cloud_name
CLOUDINARY_API_KEY=cloudinary_test_api_key
CLOUDINARY_API_SECRET=cloudinary_test_api_secret
