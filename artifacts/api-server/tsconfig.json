{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "noImplicitAny": false,
    "strict": false,
    "strictNullChecks": false,
    "strictPropertyInitialization": false
  },
  "include": ["src"],
  "exclude": ["src/test-runner.ts"],
  "references": [
    {
      "path": "../../lib/db-prisma"
    },
    {
      "path": "../../lib/shared-schemas"
    },
    {
      "path": "../../lib/api-zod"
    }
  ]
}
