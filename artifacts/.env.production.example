# ==========================================
# TALENTLAB PRODUCTION ENVIRONMENT VARIABLES
# ==========================================

# ── API Server & Core ──
NODE_ENV=production
PORT=8080
APP_URL=https://api.talentlab.co
FRONTEND_URL=https://talentlab.co

# ── Database (Neon Postgres) ──
DATABASE_URL=postgresql://user:password@ep-cold-shadow-123456.us-east-2.aws.neon.tech/talentlab?sslmode=require

# ── Redis (Upstash) ──
REDIS_URL=rediss://default:password@us1-upstash-redis.upstash.io:30000

# ── Authentication (JWT & Security) ──
JWT_SECRET=super_secret_jwt_key_must_be_long_and_random
JWT_EXPIRES_IN=24h
COOKIE_SECRET=super_secret_cookie_key

# ── Email Service (Resend) ──
RESEND_API_KEY=re_123456789
EMAIL_FROM_ADDRESS=noreply@talentlab.co
EMAIL_FROM_NAME="TalentLab"

# ── Storage (Cloudflare R2) ──
S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET_NAME=talentlab-production
S3_ACCESS_KEY=your_r2_access_key
S3_SECRET_KEY=your_r2_secret_key
S3_PUBLIC_DOMAIN=https://cdn.talentlab.co

# ── AI Defaults (Optional fallback) ──
AI_PROVIDER=gemini
AI_MODEL=gemini-1.5-pro
AI_API_KEY=your_default_gemini_key

# ── Observability ──
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ── Frontend Next.js (talentlab-next) ──
NEXT_PUBLIC_API_URL=https://api.talentlab.co/api/v1
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/1
