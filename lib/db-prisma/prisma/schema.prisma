model Interview {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String          @map("tenant_id") @db.Uuid
  pipelineId      String          @map("pipeline_id") @db.Uuid
  interviewerId   String?         @map("interviewer_id") @db.Uuid
  title           String
  interviewType   InterviewType   @default(HR) @map("interview_type")
  mode            InterviewMode   @default(VIRTUAL)
  status          InterviewStatus @default(SCHEDULED)
  roundNumber     Int             @default(1) @map("round_number")
  scheduledAt     DateTime        @map("scheduled_at")
  durationMin     Int             @default(60) @map("duration_min")
  timezone        String          @default("UTC")
  location        String?
  meetingLink     String?         @map("meeting_link")
  meetingId       String?         @map("meeting_id")
  agenda          String?
  cancellationReason String?      @map("cancellation_reason")
  completedAt     DateTime?       @map("completed_at")
  noShowAt        DateTime?       @map("no_show_at")
  hiringDecision  String?         @map("hiring_decision")
  isActive        Boolean         @default(true) @map("is_active")
  deletedAt       DateTime?       @map("deleted_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  tenant      Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipeline    CandidatePipeline          @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  interviewer User?                      @relation("InterviewerUser", fields: [interviewerId], references: [id], onDelete: SetNull)
  panel       InterviewPanel[]
  feedback    InterviewFeedback[]
  scores      InterviewScore[]
  questions   InterviewQuestion[]
  recordings  InterviewRecording[]
  attachments InterviewAttachment[]
  timeline    InterviewTimeline[]
  reminders   InterviewReminder[]
  reschedules InterviewRescheduleHistory[]

  @@index([pipelineId])
  @@index([status])
  @@map("interviews")
}

