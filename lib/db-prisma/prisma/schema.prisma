  pipeline CandidatePipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("candidate_share_links")
}

enum AllocationStatus {
  AVAILABLE
  ALLOCATED
  INTERVIEW_SCHEDULED
  SELECTED
  OFFER_RELEASED
  JOINED
  REJECTED
  ON_HOLD
  BLACKLISTED
}

model CandidateAllocationStatus {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  candidateId String           @unique @map("candidate_id") @db.Uuid
  status      AllocationStatus @default(AVAILABLE)
  reason      String?
  updatedById String?          @map("updated_by_id") @db.Uuid
  updatedAt   DateTime         @updatedAt @map("updated_at")
  createdAt   DateTime         @default(now()) @map("created_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_allocation_statuses")
}

// Phase 16: SaaS Multi-Tenant Platform Models

model SubscriptionPlan {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                   String   @unique
  displayName            String   @map("display_name")
  priceMonthly           Decimal  @default(0) @map("price_monthly")
  priceYearly            Decimal  @default(0) @map("price_yearly")
  isActive               Boolean  @default(true) @map("is_active")
  maxRecruiters          Int?     @map("max_recruiters")
  maxCandidates          Int?     @map("max_candidates")
  maxCompanies           Int?     @map("max_companies")
  maxJobs                Int?     @map("max_jobs")
  maxStorageMb           Int?     @map("max_storage_mb")
  maxAiCreditsMonthly    Int?     @map("max_ai_credits_monthly")
  maxAssessments         Int?     @map("max_assessments")
  maxActivePipelines     Int?     @map("max_active_pipelines")
  maxResumeParsesMonthly Int?     @map("max_resume_parses_monthly")
  maxAiMatchesMonthly    Int?     @map("max_ai_matches_monthly")
  maxEmailsMonthly       Int?     @map("max_emails_monthly")
  features               Json     @default("{}")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")
  subscriptions          TenantSubscription[]
  @@map("subscription_plans")
}

model TenantSubscription {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String    @unique @map("tenant_id") @db.Uuid
  planId               String    @map("plan_id") @db.Uuid
  status               String    @default("TRIAL")
  trialEndsAt          DateTime? @map("trial_ends_at")
  currentPeriodStart   DateTime  @map("current_period_start")
  currentPeriodEnd     DateTime  @map("current_period_end")
  cancelledAt          DateTime? @map("cancelled_at")
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  tenant               Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                 SubscriptionPlan @relation(fields: [planId], references: [id])
  @@map("tenant_subscriptions")
}

model TenantUsage {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  periodMonth       Int      @map("period_month")
  periodYear        Int      @map("period_year")
  aiCreditsUsed     Int      @default(0) @map("ai_credits_used")
  resumeParsesUsed  Int      @default(0) @map("resume_parses_used")
  aiMatchesUsed     Int      @default(0) @map("ai_matches_used")
  emailsSentUsed    Int      @default(0) @map("emails_sent_used")
  storageMbUsed     Decimal  @default(0) @map("storage_mb_used")
  updatedAt         DateTime @updatedAt @map("updated_at")
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@unique([tenantId, periodMonth, periodYear])
  @@map("tenant_usages")
}

model WorkspaceInvite {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  email       String
  roleId      String    @map("role_id") @db.Uuid
  token       String    @unique
  invitedById String    @map("invited_by_id") @db.Uuid
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("SentInvites", fields: [invitedById], references: [id])
  role        Role      @relation(fields: [roleId], references: [id])
  @@index([token])
  @@map("workspace_invites")
}

// -----------------------------------------------------------------------------
// WORKFLOW AUTOMATION (SPRINT 5)
// -----------------------------------------------------------------------------

model Workflow {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  description String?
  triggerEvent String  @map("trigger_event") // e.g., CANDIDATE_CREATED, INTERVIEW_SCHEDULED
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  steps       WorkflowStep[]
  executions  WorkflowExecution[]

  @@map("workflows")
}

model WorkflowStep {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflowId  String   @map("workflow_id") @db.Uuid
  type        String   // e.g., SEND_EMAIL, SEND_WHATSAPP
  config      Json     @default("{}") // Store template IDs, subject, body, etc.
  order       Int      // Sequential execution order
  createdAt   DateTime @default(now()) @map("created_at")

  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("workflow_steps")
}

model WorkflowExecution {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflowId  String   @map("workflow_id") @db.Uuid
  status      String   // PENDING, COMPLETED, FAILED
  payload     Json     @default("{}") // What triggered this execution
  logs        Json     @default("[]") // Array of execution step logs
  startedAt   DateTime @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("workflow_executions")
}
