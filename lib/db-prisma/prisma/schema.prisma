datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum SystemRole {
  SUPER_ADMIN
  TENANT_ADMIN
  RECRUITER
  HR
  CLIENT_USER
  CANDIDATE
}

enum UrgencyLevel {
  CRITICAL
  HIGH
  NORMAL
}

enum JobStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  OPEN
  ON_HOLD
  CLOSED
  CANCELLED
  ARCHIVED
}

enum CandidateSource {
  REFERRAL
  PORTAL
  SOCIAL
  INTERNAL
  DIRECT
}

enum PipelineStage {
  SOURCED
  SCREENED
  ASSESSED
  SHORTLISTED
  CLIENT_INTERVIEW
  OFFER
  JOINING
  POST_JOINING
  REJECTED
  DROPPED
}

enum Verdict {
  SHORTLIST
  HOLD
  REJECT
}

enum AssessmentCategory {
  APTITUDE
  MATHEMATICS
  ENGLISH
  LOGICAL_REASONING
  COMPUTER_KNOWLEDGE
  GENERAL_KNOWLEDGE
  CURRENT_AFFAIRS
  TECHNICAL
}

enum InterviewVerdict {
  SELECTED
  ON_HOLD
  REJECTED
  NO_SHOW
}

enum InterviewType {
  HR
  TECHNICAL
  MANAGER
  FINAL
  BEHAVIORAL
  SYSTEM_DESIGN
  CODING
  CUSTOM
}

enum InterviewMode {
  VIRTUAL
  IN_PERSON
  PHONE
  PANEL
}

enum InterviewStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum OfferStatus {
  DRAFTED
  PENDING_APPROVAL
  APPROVED
  SENT
  ACCEPTED
  REJECTED
  REVOKED
}

enum RetentionStatus {
  RETAINED
  RESIGNED
  TERMINATED
  UNKNOWN
}

model Tenant {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  settings               TenantSetting?
  roles                  Role[]
  users                  User[]
  companies              Company[]
  companyContacts        CompanyContact[]
  candidates             Candidate[]
  jobs                   Job[]
  candidatePipelines     CandidatePipeline[]
  screeningInterviews    ScreeningInterview[]
  screeningCriteriaScores ScreeningCriteriaScore[]
  assessmentTests        AssessmentTest[]
  assessmentTemplates    AssessmentTemplate[]
  clientInterviews       ClientInterview[]
  salaryNegotiations     SalaryNegotiation[]
  offerLetters           OfferLetter[]
  offerApprovals         OfferApproval[]
  joiningStatuses        JoiningStatus[]
  postJoiningFollowups   PostJoiningFollowup[]
  activityLogs           ActivityLog[]
  notifications          Notification[]
  pipelineHistories      PipelineHistory[]
  pipelineNotes          PipelineNote[]
  pipelineAttachments    PipelineAttachment[]
  pipelineRatings        PipelineRating[]
  pipelineChecklists     PipelineChecklist[]
  pipelineReminders      PipelineReminder[]
  pipelineActivities     PipelineActivity[]
  pipelineTags           PipelineTag[]

  interviews             Interview[]
  interviewPanels        InterviewPanel[]
  interviewFeedbacks     InterviewFeedback[]
  interviewTimelines     InterviewTimeline[]
  interviewReminders     InterviewReminder[]
  interviewAvailabilities InterviewAvailability[]

  candidateAddresses     CandidateAddress[]
  candidateEducations    CandidateEducation[]
  candidateExperiences   CandidateExperience[]
  candidateSkills        CandidateSkill[]
  candidateLanguages     CandidateLanguage[]
  candidateCertifications CandidateCertification[]
  candidateDocuments     CandidateDocument[]
  candidateTags          CandidateTag[]
  candidateNotes         CandidateNote[]
  candidateTimelines     CandidateTimeline[]
  savedFilters           SavedFilter[]
  outboxEvents           OutboxEvent[]
  workflows              Workflow[]

  companyAddresses       CompanyAddress[]
  companyDepartments     CompanyDepartment[]
  companyDocuments       CompanyDocument[]
  companyTags            CompanyTag[]
  companyNotes           CompanyNote[]
  companyTimelines       CompanyTimeline[]
  recruiterAssignments   RecruiterAssignment[]

  jobDepartments         JobDepartment[]
  jobLocations           JobLocation[]
  jobRequirements        JobRequirement[]
  jobSkills              JobSkill[]
  jobQuestions           JobQuestion[]
  jobTags                JobTag[]
  jobTimelines           JobTimeline[]
  jobDocuments           JobDocument[]
  jobRecruiterAssignments JobRecruiterAssignment[]
  jobHiringManagerAssignments JobHiringManagerAssignment[]
  jobStatusHistories     JobStatusHistory[]

  aiAnalyses             AiAnalysis[]
  candidateShareLinks    CandidateShareLink[]
  candidateAllocationStatuses CandidateAllocationStatus[]

  subscription           TenantSubscription?
  usages                 TenantUsage[]
  workspaceInvites       WorkspaceInvite[]

  @@map("tenants")
}

model TenantSetting {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String   @unique @map("tenant_id") @db.Uuid

  // Legacy / existing fields (preserved exactly)
  brandingColor        String?  @map("branding_color")
  allowedLoginDomains  Json     @default("[]") @map("allowed_login_domains")
  timezone             String   @default("UTC")
  enableAiCopilot      Boolean  @default(true) @map("enable_ai_copilot")

  // Branding (Phase 16)
  logoUrl              String?  @map("logo_url")
  faviconUrl           String?  @map("favicon_url")
  primaryColor         String?  @map("primary_color")

  // Company Info (Phase 16)
  companyName          String?  @map("company_name")
  companyWebsite       String?  @map("company_website")
  companyAddress       String?  @map("company_address")
  companyPhone         String?  @map("company_phone")

  // Locale (Phase 16)
  currency             String   @default("INR")
  language             String   @default("en")
  dateFormat           String   @default("DD/MM/YYYY") @map("date_format")

  // Email Config (Phase 16)
  emailFromName        String?  @map("email_from_name")
  emailFromAddress     String?  @map("email_from_address")
  emailReplyTo         String?  @map("email_reply_to")
  emailSignature       String?  @map("email_signature")

  // AI Config per workspace (Phase 16 — workspace-level override)
  aiProvider           String   @default("openai") @map("ai_provider")
  aiModel              String?  @map("ai_model")
  aiBaseUrl            String?  @map("ai_base_url")
  aiApiKeyEncrypted    String?  @map("ai_api_key_encrypted")

  // Notification toggles (Phase 16)
  notifyOnNewCandidate Boolean  @default(true) @map("notify_on_new_candidate")
  notifyOnStageChange  Boolean  @default(true) @map("notify_on_stage_change")
  notifyOnOfferRelease Boolean  @default(true) @map("notify_on_offer_release")
  notifyOnAssessment   Boolean  @default(true) @map("notify_on_assessment")
  notifyOnJoining      Boolean  @default(true) @map("notify_on_joining")

  updatedAt            DateTime @updatedAt @map("updated_at")

  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model Role {
  id           String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String                  @map("tenant_id") @db.Uuid
  name         String
  isSystemRole Boolean                 @default(false) @map("is_system_role")
  createdAt    DateTime                @default(now()) @map("created_at")

  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users        User[]
  permissions  RolePermissionMapping[]
  workspaceInvites WorkspaceInvite[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id          String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String                  @unique
  description String
  roles       RolePermissionMapping[]

  @@map("permissions")
}

model RolePermissionMapping {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permission_mappings")
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  companyId    String?   @map("company_id") @db.Uuid
  roleId       String    @map("role_id") @db.Uuid
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  systemRole   SystemRole @default(RECRUITER) @map("system_role")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company              Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  role                 Role                 @relation(fields: [roleId], references: [id])
  sessions             UserSession[]
  preferences          UserPreference?
  recruitedJobs        Job[]                @relation("RecruiterJobs")
  assignedPipelines    CandidatePipeline[]  @relation("AssignedRecruiter")
  conductedAssessments AssessmentTest[]     @relation("ConductedBy")
  activityLogs         ActivityLog[]        @relation("PerformedBy")
  notifications        Notification[]       @relation("Recipient")
  candidateNotes       CandidateNote[]      @relation("NoteAuthor")
  candidateTimelineEvents CandidateTimeline[]   @relation("EventPerformer")
  savedFilters         SavedFilter[]
  companyNotes         CompanyNote[]        @relation("CompanyNoteAuthor")
  companyTimelineEvents CompanyTimeline[]   @relation("CompanyEventPerformer")
  recruiterAssignments RecruiterAssignment[] @relation("AssignedRecruiter")
  recruiterAssignedBy  RecruiterAssignment[] @relation("AssignedBy")

  approvedJobs            Job[]                      @relation("ApprovedJobs")
  jobTimelineEvents       JobTimeline[]              @relation("JobTimelinePerformer")
  recruiterAssignedJobs   JobRecruiterAssignment[]   @relation("JobRecruiterUser")
  recruiterJobAssignedBy  JobRecruiterAssignment[]   @relation("JobRecruiterAssignedBy")
  hmAssignedJobs          JobHiringManagerAssignment[] @relation("JobHMUser")
  hmJobAssignedBy         JobHiringManagerAssignment[] @relation("JobHMAssignedBy")
  jobStatusChanges        JobStatusHistory[]         @relation("JobStatusChangedBy")

  changedPipelineStatuses PipelineHistory[]          @relation("PipelineStatusChangedBy")
  pipelineNotes           PipelineNote[]             @relation("PipelineNoteAuthor")
  uploadedPipelineAttachments PipelineAttachment[]   @relation("PipelineAttachmentUploadedBy")
  pipelineRatings         PipelineRating[]           @relation("PipelineRatingBy")
  completedPipelineChecklists PipelineChecklist[]    @relation("PipelineChecklistCompletedBy")
  pipelineReminders       PipelineReminder[]         @relation("PipelineReminderFor")
  pipelineActivities      PipelineActivity[]         @relation("PipelineActivityPerformer")

  interviewsAsInterviewer  Interview[]                @relation("InterviewerUser")
  interviewPanels          InterviewPanel[]           @relation("PanelMemberUser")
  interviewFeedbacks       InterviewFeedback[]        @relation("FeedbackSubmittedBy")
  interviewReschedules     InterviewRescheduleHistory[] @relation("RescheduledBy")
  interviewTimelines       InterviewTimeline[]        @relation("InterviewTimelinePerformer")
  interviewReminders       InterviewReminder[]        @relation("InterviewReminderFor")
  interviewAvailabilities  InterviewAvailability[]    @relation("AvailabilityUser")

  screeningInterviewsAsInterviewer ScreeningInterview[] @relation("ScreeningInterviewer")
  approvedOffers                   OfferApproval[]      @relation("OfferApprover")
  sentInvites                      WorkspaceInvite[]    @relation("SentInvites")

  @@map("users")
}

model UserSession {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  refreshTokenHash String   @map("refresh_token_hash")
  ipAddress        String?  @map("ip_address")
  userAgent        String?  @map("user_agent")
  expiresAt        DateTime @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model UserPreference {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String   @unique @map("user_id") @db.Uuid
  theme              String   @default("light")
  emailNotifications Boolean  @default(true) @map("email_notifications")
  calendarTokenEnc   String?  @map("calendar_token_enc")

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Company {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  name            String
  industry        String?
  website         String?
  gstin           String?   @map("gstin")
  pan             String?
  cin             String?
  email           String?
  phone           String?
  employeeCount   Int?      @map("employee_count")
  companyType     String    @default("PRIVATE_LIMITED") @map("company_type")
  logoUrl         String?   @map("logo_url")
  description     String?
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  archivedAt      DateTime? @map("archived_at")

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contacts        CompanyContact[]
  users           User[]
  jobs            Job[]
  address         CompanyAddress?
  departments     CompanyDepartment[]
  documents       CompanyDocument[]
  tags            CompanyTag[]
  notes           CompanyNote[]
  timeline        CompanyTimeline[]
  recruiters      RecruiterAssignment[]

  @@map("companies")
}

model CompanyContact {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  companyId    String    @map("company_id") @db.Uuid
  name         String
  email        String?
  phone        String?
  designation  String?
  contactType  String    @default("HR") @map("contact_type")
  linkedinUrl  String?   @map("linkedin_url")
  notes        String?
  isPrimary    Boolean   @default(false) @map("is_primary")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientInterviews ClientInterview[]

  @@map("company_contacts")
}

model CompanyAddress {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  companyId    String   @unique @map("company_id") @db.Uuid
  addressLine1 String   @map("address_line_1")
  addressLine2 String?  @map("address_line_2")
  city         String
  state        String
  postalCode   String   @map("postal_code")
  country      String   @default("India")
  addressType  String   @default("REGISTERED") @map("address_type")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("company_addresses")
}

model CompanyDepartment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  name        String
  headName    String?  @map("head_name")
  headEmail   String?  @map("head_email")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, companyId, name])
  @@map("company_departments")
}

model CompanyDocument {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  name         String
  documentType String   @map("document_type")
  fileUrl      String   @map("file_url")
  fileKey      String?  @map("file_key")
  fileSize     Int?     @map("file_size")
  checksum     String?
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("company_documents")
}

model CompanyTag {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, companyId, name])
  @@map("company_tags")
}

model CompanyNote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  authorId  String?  @map("author_id") @db.Uuid
  content   String
  isPrivate Boolean  @default(false) @map("is_private")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author  User?   @relation("CompanyNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@map("company_notes")
}

model CompanyTimeline {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  companyId     String   @map("company_id") @db.Uuid
  eventType     String   @map("event_type")
  title         String
  description   String?
  metadata      Json?
  performedById String?  @map("performed_by_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  performedBy User?   @relation("CompanyEventPerformer", fields: [performedById], references: [id], onDelete: SetNull)

  @@map("company_timelines")
}

model RecruiterAssignment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  assignedById String? @map("assigned_by_id") @db.Uuid
  isLead      Boolean  @default(false) @map("is_lead")
  assignedAt  DateTime @default(now()) @map("assigned_at")

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User    @relation("AssignedRecruiter", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy User?   @relation("AssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([tenantId, companyId, userId])
  @@map("recruiter_assignments")
}

model Candidate {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String          @map("tenant_id") @db.Uuid
  name            String
  initials        String?
  email           String          @unique
  phone           String?
  currentRole     String?         @map("current_role")
  experienceYears Int?            @map("experience_years")
  location        String?
  skills          String[]
  source          CandidateSource @default(PORTAL)
  currentCtc      Int?            @map("current_ctc")
  expectedCtc     Int?            @map("expected_ctc")
  noticeDays      Int?            @map("notice_days")
  summary         String?
  questionnaireResponses Json?   @map("questionnaire_responses")
  resumeUrl       String?         @map("resume_url")
  photoUrl        String?         @map("photo_url")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipelines CandidatePipeline[]

  address        CandidateAddress?
  educations     CandidateEducation[]
  experiences    CandidateExperience[]
  skillsList     CandidateSkill[]
  languages      CandidateLanguage[]
  certifications CandidateCertification[]
  documents      CandidateDocument[]
  tags           CandidateTag[]
  notes          CandidateNote[]
  timeline       CandidateTimeline[]
  allocationStatus CandidateAllocationStatus?

  @@index([tenantId])
  @@map("candidates")
}

model Job {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  companyId     String       @map("company_id") @db.Uuid
  recruiterId   String?      @map("recruiter_id") @db.Uuid
  code          String       @map("code")
  title         String
  description   String?
  location      String
  jobType       String       @default("full_time") @map("job_type")
  urgency       UrgencyLevel @default(NORMAL)
  salaryBand    String?      @map("salary_band")
  salaryMin     Int?         @map("salary_min")
  salaryMax     Int?         @map("salary_max")
  currency      String       @default("INR")
  minExperience Int?         @map("min_experience")
  maxExperience Int?         @map("max_experience")
  jdText        String?      @map("jd_text")
  openingsCount Int          @default(1) @map("openings_count")
  status        JobStatus    @default(DRAFT)
  approvedById  String?      @map("approved_by_id") @db.Uuid
  approvedAt    DateTime?    @map("approved_at")
  deadline      DateTime?
  archivedAt    DateTime?    @map("archived_at")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")

  tenant         Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company        Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  recruiter      User?                       @relation("RecruiterJobs", fields: [recruiterId], references: [id], onDelete: SetNull)
  approvedBy     User?                       @relation("ApprovedJobs", fields: [approvedById], references: [id], onDelete: SetNull)
  pipelines      CandidatePipeline[]
  departments    JobDepartment[]
  locations      JobLocation[]
  requirements   JobRequirement[]
  skills         JobSkill[]
  questions      JobQuestion[]
  tags           JobTag[]
  timeline       JobTimeline[]
  documents      JobDocument[]
  recruiters     JobRecruiterAssignment[]
  hiringManagers JobHiringManagerAssignment[]
  statusHistory  JobStatusHistory[]

  @@unique([tenantId, code])
  @@map("jobs")
}

model CandidatePipeline {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String        @map("tenant_id") @db.Uuid
  candidateId        String        @map("candidate_id") @db.Uuid
  jobId              String        @map("job_id") @db.Uuid
  stage              PipelineStage @default(SOURCED)
  assignedRecruiterId String?       @map("assigned_recruiter_id") @db.Uuid
  stageUpdatedAt     DateTime      @default(now()) @map("stage_updated_at")
  notes              String?
  deletedAt          DateTime?     @map("deleted_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate          Candidate            @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job                Job                  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  assignedRecruiter  User?                @relation("AssignedRecruiter", fields: [assignedRecruiterId], references: [id], onDelete: SetNull)
